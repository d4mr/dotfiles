# Sourced only for interactive shells. Env vars live in ~/.zshenv.

eval "$(starship init zsh)"

source $(brew --prefix)/share/zsh-autosuggestions/zsh-autosuggestions.zsh
source $(brew --prefix)/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
eval "$(zoxide init zsh)"

# Machine-local work/secret env — not tracked
[ -f ~/.zshrc.local ] && source ~/.zshrc.local

# mise — interactive activation hooks (auto-switch on cd).
# Shims PATH is already in .zshenv so non-interactive shells work too.
eval "$(mise activate zsh)"

# bun completions
[ -s "$BUN_INSTALL/_bun" ] && source "$BUN_INSTALL/_bun"
